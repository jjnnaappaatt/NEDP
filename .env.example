# NEDP web app (Next.js). Copy to .env.local and fill in.
# NEVER commit real secrets — only .env.example (placeholders) is tracked.
# Until these are set, the app keeps running on the built-in mock data (lib/mock).

# ── Data source toggle ───────────────────────────────────────────────────────
# 'mock' (default, zero backend needed) | 'supabase'
NEXT_PUBLIC_DATA_SOURCE=mock

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>          # browser (RLS enforced)
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>             # server-only, never expose to the browser

# ── LINE Login / LIFF (open the web app inside LINE with LINE identity) ──────
NEXT_PUBLIC_LIFF_ID=<liff-id>                            # from the LINE Login channel's LIFF tab
LINE_LOGIN_CHANNEL_ID=<login-channel-id>
LINE_LOGIN_CHANNEL_SECRET=<login-channel-secret>

# ── LINE Messaging API (push messages, webhook, rich menu) ──────────────────
LINE_CHANNEL_ACCESS_TOKEN=<messaging-api-channel-access-token>
LINE_CHANNEL_SECRET=<messaging-api-channel-secret>       # verifies X-Line-Signature on inbound webhooks

# ── Sessions ─────────────────────────────────────────────────────────────────
ADMIN_PORTAL_PASSWORD=<shared-admin-password>            # gates /admin/login
ADMIN_SESSION_SECRET=<random-long-string>                # HMAC-signs the admin session cookie
ACCOUNT_SESSION_SECRET=<random-long-string>              # HMAC-signs the per-LINE-user nedp_account cookie (falls back to ADMIN_SESSION_SECRET if unset)

# ── Scheduled reminders (pg_cron → this app's cron route) ───────────────────
CRON_SECRET=<random-long-string>                         # bearer token the cron job must present
REMINDER_UTC_OFFSET_HOURS=7                              # Thailand = UTC+7

# ── App URL (used in absolute links, e.g. LINE messages) ────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
