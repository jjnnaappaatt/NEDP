# NEDP web app (Next.js) — production env. Copy to .env.local and fill in.
# ⚠ NEXT_PUBLIC_* are inlined at BUILD time — they must be present in the Vercel *build* env, not only at runtime.

# ── Data source ──────────────────────────────────────────────────────────────
# 'supabase' for a real deployment. 'mock' serves in-memory data and SILENTLY
# DISCARDS every write (success toast, zero persistence) — never ship 'mock' to prod.
NEXT_PUBLIC_DATA_SOURCE=supabase                          # REQUIRED IN PROD = supabase

# ── Supabase (shared DB with the LINE bot) ───────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co   # REQUIRED — all DB dead if unset
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>          # present for completeness; the app uses the service role, no RLS browser path
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>             # REQUIRED, server-only — never expose to the browser

# ── LINE Login / LIFF (open the web app inside LINE with LINE identity) ──────
NEXT_PUBLIC_LIFF_ID=<liff-id>                            # from the LINE Login channel's LIFF tab; in-LINE login can't mint a token if unset
LINE_LOGIN_CHANNEL_ID=<login-channel-id>                 # REQUIRED — link/subscribe/claim 500 if unset (fail-closed)
LINE_LOGIN_CHANNEL_SECRET=<login-channel-secret>

# ── Sessions & admin ─────────────────────────────────────────────────────────
ADMIN_SESSION_SECRET=<random-long-string>                # REQUIRED — HMAC-signs the admin cookie; admin login 500s if unset
ACCOUNT_SESSION_SECRET=<random-long-string>              # HMAC-signs the nedp_account cookie (falls back to ADMIN_SESSION_SECRET). No user can log in if both unset.
ADMIN_PORTAL_PASSWORD=<high-entropy-password>            # REQUIRED IN PROD — shared admin login; unset ⇒ whole /admin portal 401s (fail-closed)

# ── LINE Messaging + reminder cron (bot sends & inbound) ─────────────────────
LINE_CHANNEL_ACCESS_TOKEN=<messaging-api-access-token>   # REQUIRED IN PROD — unset ⇒ every LINE push silently no-ops (reminders/approvals/invites undelivered)
LINE_CHANNEL_SECRET=<messaging-api-channel-secret>       # REQUIRED IN PROD — unset ⇒ webhook rejects all inbound (RSVP/commands) 401 (fail-closed)
CRON_SECRET=<random-long-string>                         # REQUIRED IN PROD — unset ⇒ reminder cron 401s, zero reminders ever sent (fail-closed)

# ── Public base URL ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://<your-prod-domain>           # REQUIRED IN PROD if the domain differs from aainextdashboard.vercel.app;
                                                         # else LINE deep-links / share / OG / sitemap point at the wrong host
